---
interface Props {
  title: string;
  description: string;
  lang: string;
  canonicalUrl?: string;
  ogImage?: string;
}

const { title, description, lang, canonicalUrl, ogImage } = Astro.props;
const currentPath = Astro.url.pathname;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') || '';
const canonical = canonicalUrl || `${siteUrl}${currentPath}`;
const dir = lang === 'ar' ? 'rtl' : 'ltr';

const locales = ['en', 'es', 'zh', 'ru', 'pt', 'ar'];
const langNames: Record<string, string> = {
  en: 'English',
  es: 'Espanol',
  zh: '中文',
  ru: 'Русский',
  pt: 'Portugues',
  ar: 'العربية',
};
---

<!doctype html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="robots" content="index, follow" />

    <!-- Google Fonts - Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Hreflang -->
    {locales.map((loc) => {
      const path = currentPath.replace(`/${lang}/`, `/${loc}/`);
      return <link rel="alternate" hreflang={loc} href={`${siteUrl}${path}`} />;
    })}
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}/en/`} />

    <!-- Google AdSense -->
    <script
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-2701690512336282"
      crossorigin="anonymous"
    ></script>

    <style is:global>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        line-height: 1.6;
        color: #e2e8f0;
        background: #0a0b10;
      }
      a {
        color: #2563eb;
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
        color: #eab308;
      }
      .container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 20px;
      }

      /* Header - dark with blur */
      header {
        background: rgba(10, 11, 16, 0.85);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border-bottom: 1px solid rgba(37, 99, 235, 0.15);
        color: white;
        padding: 16px 0;
        position: sticky;
        top: 0;
        z-index: 100;
      }
      header .container {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 12px;
      }
      .logo {
        font-size: 1.4rem;
        font-weight: 800;
        color: white;
        background: linear-gradient(135deg, #2563eb, #eab308);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }
      .logo:hover {
        text-decoration: none;
      }
      nav {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
      }
      nav a {
        color: #94a3b8;
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 0.85rem;
        transition: all 0.2s;
      }
      nav a:hover,
      nav a.active {
        color: #eab308;
        background: rgba(234, 179, 8, 0.1);
        text-decoration: none;
      }

      main {
        min-height: 70vh;
      }

      /* Footer - dark */
      footer {
        background: #06070b;
        border-top: 1px solid rgba(37, 99, 235, 0.1);
        color: #64748b;
        padding: 32px 0;
        text-align: center;
        font-size: 0.85rem;
      }

      /* Ad slots - dark themed */
      .ad-slot {
        background: rgba(37, 99, 235, 0.03);
        border: 1px dashed rgba(37, 99, 235, 0.2);
        border-radius: 8px;
        padding: 20px;
        text-align: center;
        margin: 24px 0;
        min-height: 90px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #64748b;
        font-size: 0.8rem;
      }

      /* Hero - fullscreen with animated gradient and grid overlay */
      .hero {
        position: relative;
        text-align: center;
        padding: 100px 20px 80px;
        background: linear-gradient(135deg, #0a0b10 0%, #0a1628 30%, #0a0b10 60%, #0d1117 100%);
        color: white;
        overflow: hidden;
        min-height: 80vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
      }
      .hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image:
          linear-gradient(rgba(37, 99, 235, 0.06) 1px, transparent 1px),
          linear-gradient(90deg, rgba(37, 99, 235, 0.06) 1px, transparent 1px);
        background-size: 60px 60px;
        animation: gridMove 20s linear infinite;
      }
      .hero::after {
        content: '';
        position: absolute;
        top: 20%;
        left: 50%;
        transform: translateX(-50%);
        width: 600px;
        height: 600px;
        background: radial-gradient(circle, rgba(37, 99, 235, 0.12) 0%, rgba(234, 179, 8, 0.05) 40%, transparent 70%);
        border-radius: 50%;
        pointer-events: none;
      }
      @keyframes gridMove {
        0% { transform: translate(0, 0); }
        100% { transform: translate(60px, 60px); }
      }
      .hero-content {
        position: relative;
        z-index: 2;
        max-width: 800px;
      }
      .hero-pill {
        display: inline-block;
        padding: 6px 20px;
        border-radius: 100px;
        font-size: 0.85rem;
        font-weight: 600;
        color: #eab308;
        background: rgba(234, 179, 8, 0.1);
        border: 1px solid rgba(234, 179, 8, 0.3);
        margin-bottom: 24px;
      }
      .hero h1 {
        font-size: 3.2rem;
        font-weight: 900;
        margin-bottom: 8px;
        line-height: 1.1;
      }
      .hero .gradient-text {
        background: linear-gradient(135deg, #2563eb, #eab308, #fbbf24);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        display: block;
        font-size: 3.2rem;
        font-weight: 900;
        line-height: 1.1;
        margin-bottom: 20px;
      }
      .hero .lead {
        font-size: 1.15rem;
        color: #94a3b8;
        max-width: 600px;
        margin: 0 auto 40px;
        line-height: 1.7;
      }
      .hero-stats {
        display: flex;
        justify-content: center;
        gap: 40px;
        flex-wrap: wrap;
      }
      .hero-stat {
        text-align: center;
      }
      .hero-stat .value {
        font-size: 1.5rem;
        font-weight: 800;
        color: #eab308;
      }
      .hero-stat .label {
        font-size: 0.8rem;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-top: 4px;
      }

      /* Cards - dark glassmorphism */
      .card-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 24px;
        margin: 32px 0;
      }
      .card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 16px;
        padding: 28px;
        backdrop-filter: blur(10px);
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
      }
      .card::before {
        content: '';
        position: absolute;
        inset: 0;
        border-radius: 16px;
        padding: 1px;
        background: linear-gradient(135deg, transparent, transparent);
        -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
        -webkit-mask-composite: xor;
        mask-composite: exclude;
        transition: background 0.3s ease;
        pointer-events: none;
      }
      .card:hover {
        transform: translateY(-4px);
        background: rgba(37, 99, 235, 0.05);
        border-color: rgba(37, 99, 235, 0.3);
        box-shadow: 0 20px 40px rgba(37, 99, 235, 0.1);
      }
      .card:hover::before {
        background: linear-gradient(135deg, rgba(37, 99, 235, 0.5), rgba(234, 179, 8, 0.5));
      }
      .card-icon {
        font-size: 2rem;
        margin-bottom: 12px;
        display: block;
      }
      .card h2 {
        font-size: 1.2rem;
        font-weight: 700;
        margin-bottom: 10px;
        color: #f1f5f9;
      }
      .card p {
        color: #94a3b8;
        font-size: 0.92rem;
        line-height: 1.6;
      }

      /* Registration section */
      .registration {
        margin: 60px 0;
        padding: 40px;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(37, 99, 235, 0.15);
        border-radius: 16px;
        text-align: center;
      }
      .registration h3 {
        color: #f1f5f9;
        font-size: 1.1rem;
        font-weight: 700;
        margin-bottom: 20px;
      }
      .reg-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 16px;
      }
      .reg-item {
        padding: 12px;
      }
      .reg-item .reg-label {
        font-size: 0.75rem;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 4px;
      }
      .reg-item .reg-value {
        font-size: 0.95rem;
        color: #eab308;
        font-weight: 600;
      }

      /* Section spacing */
      .section-block {
        padding: 40px 0;
      }

      @media (max-width: 640px) {
        .hero {
          padding: 60px 20px 50px;
          min-height: 60vh;
        }
        .hero h1,
        .hero .gradient-text {
          font-size: 2rem;
        }
        .hero-stats {
          gap: 24px;
        }
        .card-grid {
          grid-template-columns: 1fr;
        }
        .reg-grid {
          grid-template-columns: 1fr 1fr;
        }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="container">
        <a class="logo" href={`/${lang}/`}><slot name="logo">Interixw</slot></a>
        <nav>
          {locales.map((loc) => {
            const path = currentPath.replace(`/${lang}/`, `/${loc}/`);
            return (
              <a href={path} class={loc === lang ? 'active' : ''}>
                {langNames[loc]}
              </a>
            );
          })}
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <div class="container">
        <p>&copy; {new Date().getFullYear()} <slot name="footer-name">Interixw</slot>. All rights reserved.</p>
      </div>
    </footer>
  </body>
</html>
