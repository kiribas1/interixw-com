---
import BaseLayout from '../../layouts/BaseLayout.astro';
import OffshoreQuiz from '../../components/OffshoreQuiz.astro';
import WeeklyNews from '../../components/WeeklyNews.astro';
---

<BaseLayout
  title="Interixw - Offshore Company Formation & Business Consultancy"
  description="The bridge between your entrepreneurial vision and the most advantageous jurisdiction. Tax optimization, asset protection, and market access in BRICS nations and emerging markets."
  lang="en"
>
  <Fragment slot="logo">Interixw</Fragment>
  <Fragment slot="footer-name">Interixw</Fragment>

  <section class="hero">
    <div class="hero-content">
      <img src="/logo_interixw.webp" alt="Interixw - Global Business Setup" class="iw-hero-logo" width="180" height="180" />
      <span class="hero-pill">Offshore Business Consultancy</span>
      <h1>Interixw</h1>
      <span class="gradient-text">Get Your Business to Great Level</span>
      <p class="lead">The bridge between your entrepreneurial vision and the most advantageous jurisdiction. Tax optimization, asset protection, and market access in BRICS nations and emerging markets.</p>
      <div class="hero-stats">
        <div class="hero-stat">
          <div class="value">50+</div>
          <div class="label">Jurisdictions</div>
        </div>
        <div class="hero-stat">
          <div class="value">Full</div>
          <div class="label">Compliance</div>
        </div>
        <div class="hero-stat">
          <div class="value">Crypto</div>
          <div class="label">Accepted</div>
        </div>
      </div>
    </div>
  </section>

  <OffshoreQuiz lang="en" />

  <div class="container">
    <div class="ad-slot">Ad Space - Google AdSense</div>

    <div class="card-grid">
      <article class="card">
        <span class="card-icon">🏢</span>
        <h2>Company Formation</h2>
        <p>Offshore IBC incorporation, LLC, and foundations in tax-advantaged jurisdictions. Fast-track registration with full legal support and documentation.</p>
      </article>
      <article class="card">
        <span class="card-icon">💰</span>
        <h2>Tax Optimization</h2>
        <p>Strategic structures to minimize your tax burden while maintaining full compliance with international regulations and reporting standards.</p>
      </article>
      <article class="card">
        <span class="card-icon">🛡️</span>
        <h2>Asset Protection</h2>
        <p>Shield your personal assets from business liabilities through proper structuring. Trusts, foundations, and multi-jurisdictional strategies.</p>
      </article>
      <article class="card">
        <span class="card-icon">🌍</span>
        <h2>Market Access</h2>
        <p>Establish your business presence in BRICS nations, Kiribati, Madagascar, and other emerging markets with growing economic potential.</p>
      </article>
      <article class="card">
        <span class="card-icon">🔒</span>
        <h2>Privacy & Confidentiality</h2>
        <p>Strong shareholder privacy protections, nominee director and shareholder services, and confidential corporate structures in secure jurisdictions.</p>
      </article>
      <article class="card">
        <span class="card-icon">🏦</span>
        <h2>Corporate Banking</h2>
        <p>Merchant accounts, corporate banking solutions, KYC guidance, and support for high-risk business activities including cryptocurrency operations.</p>
      </article>
    </div>

    <div class="ad-slot">Ad Space - Google AdSense</div>
  </div>

  <WeeklyNews lang="en" />

  <div class="container">
    <div class="ad-slot">Ad Space - Google AdSense</div>

    <div class="registration">
      <h3>Company Registration</h3>
      <div class="reg-grid">
        <div class="reg-item">
          <div class="reg-label">Registration</div>
          <div class="reg-value">CP-000023</div>
        </div>
        <div class="reg-item">
          <div class="reg-label">Address</div>
          <div class="reg-value">Build 23, London (KI)</div>
        </div>
        <div class="reg-item">
          <div class="reg-label">Phone</div>
          <div class="reg-value">+38322376987</div>
        </div>
        <div class="reg-item">
          <div class="reg-label">Email</div>
          <div class="reg-value">info@interixw.com</div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
