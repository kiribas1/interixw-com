---
import BaseLayout from '../../layouts/BaseLayout.astro';
import OffshoreQuiz from '../../components/OffshoreQuiz.astro';
import WeeklyNews from '../../components/WeeklyNews.astro';
---

<BaseLayout
  title="Interixw - 离岸公司设立与商业咨询"
  description="连接您的创业愿景与最有利司法管辖区的桥梁。金砖国家和新兴市场的税务优化、资产保护和市场准入。"
  lang="zh"
>
  <Fragment slot="logo">Interixw</Fragment>
  <Fragment slot="footer-name">Interixw</Fragment>

  <section class="hero">
    <div class="hero-content">
      <img src="/logo_interixw.webp" alt="Interixw - Global Business Setup" class="iw-hero-logo" width="180" height="180" />
      <span class="hero-pill">离岸商业咨询</span>
      <h1>Interixw</h1>
      <span class="gradient-text">将您的企业提升到更高水平</span>
      <p class="lead">连接您的创业愿景与最有利司法管辖区的桥梁。金砖国家和新兴市场的税务优化、资产保护和市场准入。</p>
      <div class="hero-stats">
        <div class="hero-stat">
          <div class="value">50+</div>
          <div class="label">司法管辖区</div>
        </div>
        <div class="hero-stat">
          <div class="value">完全</div>
          <div class="label">合规</div>
        </div>
        <div class="hero-stat">
          <div class="value">加密货币</div>
          <div class="label">可接受</div>
        </div>
      </div>
    </div>
  </section>

  <OffshoreQuiz lang="zh" />

  <div class="container">
    <div class="ad-slot">广告位 - Google AdSense</div>

    <div class="card-grid">
      <article class="card">
        <span class="card-icon">🏢</span>
        <h2>公司设立</h2>
        <p>在税收优惠管辖区进行离岸IBC注册、LLC和基金会设立。快速注册，提供完整的法律支持和文件服务。</p>
      </article>
      <article class="card">
        <span class="card-icon">💰</span>
        <h2>税务优化</h2>
        <p>战略性架构帮助您最大限度降低税务负担，同时保持完全符合国际法规和报告标准。</p>
      </article>
      <article class="card">
        <span class="card-icon">🛡️</span>
        <h2>资产保护</h2>
        <p>通过适当的架构将个人资产与商业负债隔离。信托、基金会和多管辖区策略。</p>
      </article>
      <article class="card">
        <span class="card-icon">🌍</span>
        <h2>市场准入</h2>
        <p>在金砖国家、基里巴斯、马达加斯加和其他具有增长经济潜力的新兴市场建立您的商业存在。</p>
      </article>
      <article class="card">
        <span class="card-icon">🔒</span>
        <h2>隐私与保密</h2>
        <p>强大的股东隐私保护、代理董事和股东服务，以及安全管辖区中的保密企业架构。</p>
      </article>
      <article class="card">
        <span class="card-icon">🏦</span>
        <h2>企业银行</h2>
        <p>商户账户、企业银行解决方案、KYC指导，以及包括加密货币运营在内的高风险业务活动支持。</p>
      </article>
    </div>

    <div class="ad-slot">广告位 - Google AdSense</div>
  </div>

  <WeeklyNews lang="zh" />

  <div class="container">
    <div class="ad-slot">广告位 - Google AdSense</div>

    <div class="registration">
      <h3>公司注册信息</h3>
      <div class="reg-grid">
        <div class="reg-item">
          <div class="reg-label">注册号</div>
          <div class="reg-value">CP-000023</div>
        </div>
        <div class="reg-item">
          <div class="reg-label">地址</div>
          <div class="reg-value">Build 23, London (KI)</div>
        </div>
        <div class="reg-item">
          <div class="reg-label">电话</div>
          <div class="reg-value">+38322376987</div>
        </div>
        <div class="reg-item">
          <div class="reg-label">邮箱</div>
          <div class="reg-value">info@interixw.com</div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
