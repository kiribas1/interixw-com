---
import BaseLayout from '../../layouts/BaseLayout.astro';
import OffshoreQuiz from '../../components/OffshoreQuiz.astro';
import WeeklyNews from '../../components/WeeklyNews.astro';
---

<BaseLayout
  title="Interixw - تأسيس الشركات الخارجية والاستشارات التجارية"
  description="الجسر بين رؤيتك الريادية والولاية القضائية الأكثر فائدة. تحسين الضرائب وحماية الأصول والوصول إلى الأسواق في دول بريكس والأسواق الناشئة."
  lang="ar"
>
  <Fragment slot="logo">Interixw</Fragment>
  <Fragment slot="footer-name">Interixw</Fragment>

  <section class="hero">
    <div class="hero-content">
      <img src="/logo_interixw.webp" alt="Interixw - Global Business Setup" class="iw-hero-logo" width="180" height="180" />
      <span class="hero-pill">استشارات الأعمال الخارجية</span>
      <h1>Interixw</h1>
      <span class="gradient-text">ارتقِ بعملك إلى مستوى عظيم</span>
      <p class="lead">الجسر بين رؤيتك الريادية والولاية القضائية الأكثر فائدة. تحسين الضرائب وحماية الأصول والوصول إلى الأسواق في دول بريكس والأسواق الناشئة.</p>
      <div class="hero-stats">
        <div class="hero-stat">
          <div class="value">+50</div>
          <div class="label">ولاية قضائية</div>
        </div>
        <div class="hero-stat">
          <div class="value">كامل</div>
          <div class="label">الامتثال</div>
        </div>
        <div class="hero-stat">
          <div class="value">العملات المشفرة</div>
          <div class="label">مقبولة</div>
        </div>
      </div>
    </div>
  </section>

  <OffshoreQuiz lang="ar" />

  <div class="container">
    <div class="ad-slot">مساحة إعلانية - Google AdSense</div>

    <div class="card-grid">
      <article class="card">
        <span class="card-icon">🏢</span>
        <h2>تأسيس الشركات</h2>
        <p>تأسيس شركات IBC الخارجية وشركات LLC والمؤسسات في ولايات قضائية ذات مزايا ضريبية. تسجيل سريع مع دعم قانوني كامل وتوثيق.</p>
      </article>
      <article class="card">
        <span class="card-icon">💰</span>
        <h2>تحسين الضرائب</h2>
        <p>هياكل استراتيجية لتقليل العبء الضريبي مع الحفاظ على الامتثال الكامل للوائح الدولية ومعايير الإبلاغ.</p>
      </article>
      <article class="card">
        <span class="card-icon">🛡️</span>
        <h2>حماية الأصول</h2>
        <p>حماية أصولك الشخصية من المسؤوليات التجارية من خلال الهيكلة المناسبة. صناديق الائتمان والمؤسسات والاستراتيجيات متعددة الولايات القضائية.</p>
      </article>
      <article class="card">
        <span class="card-icon">🌍</span>
        <h2>الوصول إلى الأسواق</h2>
        <p>أسس حضور عملك في دول بريكس وكيريباتي ومدغشقر والأسواق الناشئة الأخرى ذات الإمكانات الاقتصادية المتنامية.</p>
      </article>
      <article class="card">
        <span class="card-icon">🔒</span>
        <h2>الخصوصية والسرية</h2>
        <p>حماية قوية لخصوصية المساهمين وخدمات المديرين والمساهمين الاسميين والهياكل المؤسسية السرية في ولايات قضائية آمنة.</p>
      </article>
      <article class="card">
        <span class="card-icon">🏦</span>
        <h2>الخدمات المصرفية للشركات</h2>
        <p>حسابات تجارية وحلول مصرفية للشركات وتوجيهات KYC ودعم للأنشطة التجارية عالية المخاطر بما في ذلك عمليات العملات المشفرة.</p>
      </article>
    </div>

    <div class="ad-slot">مساحة إعلانية - Google AdSense</div>
  </div>

  <WeeklyNews lang="ar" />

  <div class="container">
    <div class="ad-slot">مساحة إعلانية - Google AdSense</div>

    <div class="registration">
      <h3>تسجيل الشركة</h3>
      <div class="reg-grid">
        <div class="reg-item">
          <div class="reg-label">التسجيل</div>
          <div class="reg-value">CP-000023</div>
        </div>
        <div class="reg-item">
          <div class="reg-label">العنوان</div>
          <div class="reg-value">Build 23, London (KI)</div>
        </div>
        <div class="reg-item">
          <div class="reg-label">الهاتف</div>
          <div class="reg-value">+38322376987</div>
        </div>
        <div class="reg-item">
          <div class="reg-label">البريد الإلكتروني</div>
          <div class="reg-value">info@interixw.com</div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
